# ==============================================================================
#  AI Workbench — Environment Variables
#  Copy this file to .env and fill in your values
# ==============================================================================

# ─── Supabase (required for cloud sync + auth) ──────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Option A (Recommended): Configure Google provider in Supabase Dashboard:
#   Authentication → Providers → Google → Enable
#   Paste your Google Client ID and Secret there.
#   Supabase handles the entire OAuth flow — no env var needed here.
#
# Option B (Legacy fallback): Direct Google Identity Services (without Supabase)
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add authorized origins: http://localhost:3000, https://your-domain.com
#   4. Add redirect URIs: http://localhost:3000, https://your-domain.com
#   5. Copy the Client ID below:
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# ─── OAuth Portal (optional — for external OAuth portal integration) ────────
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ─── Analytics (optional — Umami self-hosted analytics) ─────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ─── Admin ─────────────────────────────────────────────────────────────────
# 管理員信箱 — 與此信箱登入的帳號將獲得管理員權限
# Admin email — the account logged in with this email gets admin privileges
VITE_ADMIN_EMAIL=

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# ─── Server-side API key encryption (required for secure key storage) ───────
# These are NEVER exposed to the client (no VITE_ prefix).
# SUPABASE_URL can be same as VITE_SUPABASE_URL — listed separately for clarity.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_ENCRYPTION_SECRET=your-32-byte-hex-secret-here

# ==============================================================================
#  Google OAuth Setup Guide (Supabase method)
# ==============================================================================
#
#  1. Create a Google Cloud project: https://console.cloud.google.com/
#  2. Enable "Google+ API" or "Google Identity" API
#  3. Go to Credentials → Create OAuth 2.0 Client ID
#     - Application type: Web application
#     - Authorized redirect URIs:
#       https://<YOUR_SUPABASE_PROJECT>.supabase.co/auth/v1/callback
#  4. Copy the Client ID and Client Secret
#  5. Go to Supabase Dashboard → Authentication → Providers → Google
#     - Enable the Google provider
#     - Paste Client ID and Client Secret
#  6. That's it! The app will automatically use Supabase Google OAuth.
#
# ==============================================================================
